{% extends 'admin.html.twig' %}

{% block admin %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Invités</h1>
        <a href="{{ path('admin_guest_add') }}" class="btn btn-primary">Ajouter</a>
    </div>

    <table class="table align-middle">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Email</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for guest in guests %}
                <tr>
                    <td>{{ guest.name }}</td>
                    <td>{{ guest.email }}</td>
                    <td>
                        {% if guest.blocked %}
                            <span class="badge bg-danger">Bloqué</span>
                        {% else %}
                            <span class="badge bg-success">Actif</span>
                        {% endif %}
                    </td>
                    <td class="d-flex gap-2">
                        <a href="{{ path('admin_guest_block', {id: guest.id}) }}" class="btn btn-sm {% if guest.blocked %}btn-success{% else %}btn-warning{% endif %}">
                            {% if guest.blocked %}Débloquer{% else %}Bloquer{% endif %}
                        </a>
                        <a href="{{ path('admin_guest_delete', {id: guest.id}) }}" class="btn btn-sm btn-danger">Supprimer</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted">Aucun invité enregistré.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}