# Environnement de test Symfony
APP_ENV=test
APP_DEBUG=1
APP_SECRET=test_secret

# Kernel utilisé par PHPUnit / WebTestCase
KERNEL_CLASS='App\Kernel'

# Base de données dédiée aux tests
# Attention : avec config/packages/test/doctrine.yaml, Symfony ajoute le suffixe _test.
# Cette URL pointe donc réellement vers inazaoui_test en environnement test.
DATABASE_URL="mysql://root:root@127.0.0.1:3306/inazaoui?serverVersion=8.0.32&charset=utf8mb4"

# Dépréciations Symfony
SYMFONY_DEPRECATIONS_HELPER=999999

# Panther, seulement utile si des tests navigateur sont ajoutés plus tard
PANTHER_APP_ENV=panther
PANTHER_ERROR_SCREENSHOT_DIR=./var/error-screenshots